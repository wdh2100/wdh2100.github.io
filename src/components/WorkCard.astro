---
interface Props {
  title: string;
  venue: string;
  role: string;
  detail: string;
  skill: string;
  year: string;
  link?: string;
}

const { title, venue, role, detail, skill, year, link } = Astro.props;
const skills = skill.split(', ');
---

<div class="card">
  <div class="flex items-start justify-between gap-4 mb-2">
    <div>
      <h3 class="font-semibold text-slate-800 text-base">
        {title}
        {link && (
          <a href={link} target="_blank" class="ml-1 text-indigo-500 hover:text-indigo-700 text-sm">
            <i class="fa-solid fa-arrow-up-right-from-square"></i>
          </a>
        )}
      </h3>
      <p class="text-xs text-slate-400 mt-0.5">{venue}</p>
    </div>
    <span class="text-xs font-mono text-slate-400 whitespace-nowrap">{year}</span>
  </div>

  <p class="text-sm text-slate-500 mb-1">
    <span class="font-medium text-slate-600">Role:</span> {role}
  </p>
  <p class="text-sm text-slate-600 mb-3">{detail}</p>

  <div class="flex flex-wrap">
    {skills.map((s) => <span class="skill-badge">{s}</span>)}
  </div>
</div>
